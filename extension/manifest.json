{
  "manifest_version": 3,
  "name": "DetectorIA",
  "description": "Detecta si un trabajo de estudiante fue generado por IA. Diseñado para profesores chilenos.",
  "version": "2.0.0",
  "action": {
    "default_title": "DetectorIA",
    "default_popup": "src/popup.html"
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://api.groq.com/*", "https://*.onrender.com/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "options_page": "src/options.html"
}
